[
  {
    "name": "abbreviation without definition keeps text",
    "rules": [
      "abbreviation"
    ],
    "markdown": "text\n",
    "html": "<p>text</p>\n"
  },
  {
    "name": "invalid leaf directive stays paragraph",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::bad trailing text\n",
    "html": "<p>::bad trailing text</p>\n"
  },
  {
    "name": "invalid container directive stays paragraph",
    "rules": [
      "container_directive"
    ],
    "markdown": ":::bad trailing text\n:::\n",
    "html": "<p>:::bad trailing text\n:::</p>\n"
  },
  {
    "name": "fenced directive invalid option body falls back to children",
    "rules": [
      "fenced_directive"
    ],
    "markdown": "```{bad} title\n:not option\nbody\n```\n",
    "html": "<p>title</p>\n<p>:not option\nbody</p>\n"
  },
  {
    "name": "invalid fenced code marker stays paragraph",
    "rules": [
      "fenced_code"
    ],
    "markdown": "`` `bad`\n",
    "html": "<p>`` `bad`</p>\n"
  },
  {
    "name": "atx heading too deep stays paragraph",
    "rules": [
      "atx_heading"
    ],
    "markdown": "####### nope\n",
    "html": "<p>####### nope</p>\n"
  },
  {
    "name": "invalid setext underline stays paragraph",
    "rules": [
      "setext_heading"
    ],
    "markdown": "a\n+\n",
    "html": "<p>a\n+</p>\n"
  },
  {
    "name": "html block open tag",
    "rules": [
      "html_block"
    ],
    "markdown": "<x>\n",
    "html": "&lt;x&gt;\n"
  },
  {
    "name": "html block script close",
    "rules": [
      "html_block"
    ],
    "markdown": "<script>\ntext\n</script>\n",
    "html": "&lt;script&gt;\ntext\n&lt;/script&gt;\n"
  },
  {
    "name": "math block trims single-line opener",
    "rules": [
      "math_block"
    ],
    "markdown": "$$ x\n$$\n",
    "html": "<div class=\"math math-display\">x\n</div>\n"
  },
  {
    "name": "block spoiler stops before plain paragraph",
    "rules": [
      "block_spoiler"
    ],
    "markdown": ">! one\nplain\n",
    "html": "<div class=\"spoiler\">\n<p>one</p>\n</div>\n<p>plain</p>\n"
  },
  {
    "name": "shallow block spoiler respects container depth",
    "rules": [
      "block_spoiler"
    ],
    "max_container_depth": 1,
    "markdown": ">! one\n",
    "html": "<div class=\"spoiler\">\n<p>one</p>\n</div>\n"
  },
  {
    "name": "table bad delimiter remains paragraph",
    "rules": [
      "table"
    ],
    "markdown": "a | b\n| --- |\n",
    "html": "<p>a | b\n| --- |</p>\n"
  },
  {
    "name": "list preserves far-indented first item",
    "rules": [
      "list"
    ],
    "markdown": "-      far\n",
    "html": "<ul>\n<li>far</li>\n</ul>\n"
  },
  {
    "name": "loose list with blank continuation",
    "rules": [
      "list"
    ],
    "markdown": "- a\n\n  b\n\n\n- c\n",
    "html": "<ul>\n<li>\n<p>a</p>\n<p>b</p>\n</li>\n<li>\n<p>c</p>\n</li>\n</ul>\n"
  },
  {
    "name": "loose list with extra blank before next item",
    "rules": [
      "list"
    ],
    "markdown": "- a\n\n  b\n\n\n\n- c\n",
    "html": "<ul>\n<li>\n<p>a</p>\n<p>b</p>\n</li>\n<li>\n<p>c</p>\n</li>\n</ul>\n"
  },
  {
    "name": "list keeps trailing blanks inside final loose item",
    "rules": [
      "list"
    ],
    "markdown": "- a\n\n\n",
    "html": "<ul>\n<li>\n<p>a</p>\n</li>\n</ul>\n"
  },
  {
    "name": "abbreviation multiline title consumes continuations",
    "rules": [
      "abbreviation"
    ],
    "markdown": "*[HTML]:\n   Hyper\nnope\n\nHTML\n",
    "html": "<p>nope</p>\n<p><abbr title=\"Hyper\">HTML</abbr></p>\n"
  },
  {
    "name": "abbreviation empty title renders without title attr",
    "rules": [
      "abbreviation"
    ],
    "markdown": "*[HTML]:\n\nHTML\n",
    "html": "<p><abbr>HTML</abbr></p>\n"
  },
  {
    "name": "invalid abbreviation definition stays paragraph",
    "rules": [
      "abbreviation"
    ],
    "markdown": "*[broken\n",
    "html": "<p>*[broken</p>\n"
  },
  {
    "name": "definition marker without following space stays paragraph",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n:no space\n",
    "html": "<p>Term\n:no space</p>\n"
  },
  {
    "name": "definition continuation after blank is loose",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\n    continuation\nplain\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>\n<p>desc</p>\n<p>continuation</p>\n</dd>\n</dl>\n<p>plain</p>\n"
  },
  {
    "name": "definition without preceding term stays paragraph",
    "rules": [
      "definition_list"
    ],
    "markdown": "\n: desc\n",
    "html": "<p>: desc</p>\n"
  },
  {
    "name": "definition following term without description starts paragraph",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\nTerm2\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>desc</dd>\n</dl>\n<p>Term2</p>\n"
  },
  {
    "name": "definition following description without term starts paragraph",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\n: d\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>desc</dd>\n</dl>\n<p>: d</p>\n"
  },
  {
    "name": "definition following term and description joins list",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\nTerm2\n: d\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>desc</dd>\n<dt>Term2</dt>\n<dd>d</dd>\n</dl>\n"
  },
  {
    "name": "leaf directive with no label renders no children",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::note\n",
    "html": ""
  },
  {
    "name": "bare leaf directive marker stays paragraph",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::\n",
    "html": "<p>::</p>\n"
  },
  {
    "name": "leaf directive invalid name stays paragraph",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::1bad\n",
    "html": "<p>::1bad</p>\n"
  },
  {
    "name": "leaf directive unterminated label stays paragraph",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::bad[unterminated\n",
    "html": "<p>::bad[unterminated</p>\n"
  },
  {
    "name": "plain line with only container directive rule stays paragraph",
    "rules": [
      "container_directive"
    ],
    "markdown": "nope\n",
    "html": "<p>nope</p>\n"
  },
  {
    "name": "container directive invalid name stays paragraph",
    "rules": [
      "container_directive"
    ],
    "markdown": ":::1bad\n",
    "html": "<p>:::1bad</p>\n"
  },
  {
    "name": "bare fenced directive marker stays paragraph",
    "rules": [
      "fenced_directive"
    ],
    "markdown": "```\n",
    "html": "<p>```</p>\n"
  },
  {
    "name": "empty fenced directive renders no children",
    "rules": [
      "fenced_directive"
    ],
    "markdown": "```{note}\n```\n",
    "html": ""
  },
  {
    "name": "container directive parses escaped label and attributes",
    "rules": [
      "container_directive",
      "backslash_escape"
    ],
    "markdown": ":::note[a\\]b]{#id .a .b title=\"a\\\"b\" empty}\nbody\n:::\n",
    "html": "<p>a]b</p>\n<p>body</p>\n"
  },
  {
    "name": "invalid html declaration is escaped html block",
    "rules": [
      "html_block"
    ],
    "markdown": "<!bad\n",
    "html": "&lt;!bad\n"
  },
  {
    "name": "table escaped pipe header stays paragraph",
    "rules": [
      "table"
    ],
    "markdown": "a \\| b\n| --- |\n",
    "html": "<p>a \\| b\n| --- |</p>\n"
  },
  {
    "name": "table delimiter without pipes stays paragraph",
    "rules": [
      "table"
    ],
    "markdown": "a | b\n--- ---\n",
    "html": "<p>a | b\n--- ---</p>\n"
  },
  {
    "name": "table delimiter with invalid cell stays paragraph",
    "rules": [
      "table"
    ],
    "markdown": "| --- | bad |\n",
    "html": "<p>| --- | bad |</p>\n"
  },
  {
    "name": "table aligns and pads short body row",
    "rules": [
      "table"
    ],
    "markdown": "a | b | c\n| :--- | ---: | :---: |\n| 1 | 2 |\n",
    "html": "<table>\n<thead>\n<tr>\n<th align=\"left\">a</th>\n<th align=\"right\">b</th>\n<th align=\"center\">c</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td align=\"left\">1</td>\n<td align=\"right\">2</td>\n<td align=\"center\"></td>\n</tr>\n</tbody>\n</table>\n"
  },
  {
    "name": "shallow list folds following plain line into item",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "- item\nplain\n",
    "html": "<ul>\n<li>item\nplain</li>\n</ul>\n"
  },
  {
    "name": "shallow list parses sibling items",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "- a\n- b\n",
    "html": "<ul>\n<li>a</li>\n<li>b</li>\n</ul>\n"
  },
  {
    "name": "shallow list drops trailing blank",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "- a\n\n",
    "html": "<ul>\n<li>a</li>\n</ul>\n"
  },
  {
    "name": "shallow ordered list stops before bullet list",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "1. a\n- b\n",
    "html": "<ol>\n<li>a</li>\n</ol>\n<ul>\n<li>b</li>\n</ul>\n"
  },
  {
    "name": "shallow ordered list delimiter mismatch starts new list",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "1. a\n2) b\n",
    "html": "<ol>\n<li>a</li>\n</ol>\n<ol start=\"2\">\n<li>b</li>\n</ol>\n"
  },
  {
    "name": "shallow bullet list marker mismatch starts new list",
    "rules": [
      "list"
    ],
    "max_container_depth": 1,
    "markdown": "+ a\n- b\n",
    "html": "<ul>\n<li>a</li>\n</ul>\n<ul>\n<li>b</li>\n</ul>\n"
  },
  {
    "name": "plain line with only list rule stays paragraph",
    "rules": [
      "list"
    ],
    "markdown": "plain\n",
    "html": "<p>plain</p>\n"
  },
  {
    "name": "shallow task list applies checked marker",
    "rules": [
      "task_list"
    ],
    "max_container_depth": 1,
    "markdown": "- [x] done\n",
    "html": "<ul>\n<li><input checked=\"\" disabled=\"\" type=\"checkbox\"> done</li>\n</ul>\n"
  },
  {
    "name": "task marker before emphasis leaves emphasis first",
    "rules": [
      "task_list",
      "emphasis"
    ],
    "markdown": "- [x] *done*\n",
    "html": "<ul>\n<li><input checked=\"\" disabled=\"\" type=\"checkbox\"> <em>done</em></li>\n</ul>\n"
  },
  {
    "name": "task list image syntax is not a checkbox",
    "rules": [
      "task_list",
      "image",
      "link"
    ],
    "markdown": "- ![x](/img.png)\n",
    "html": "<ul>\n<li><img src=\"/img.png\" alt=\"x\" /></li>\n</ul>\n"
  },
  {
    "name": "unclosed image opener stays text",
    "rules": [
      "link",
      "image"
    ],
    "markdown": "![alt\n",
    "html": "<p>![alt</p>\n"
  },
  {
    "name": "nested link image uses plain alt text",
    "rules": [
      "link",
      "image"
    ],
    "markdown": "![[link](/url)](/image)\n",
    "html": "<p><img src=\"/image\" alt=\"link\" /></p>\n"
  },
  {
    "name": "image alt preserves hard break as newline",
    "rules": [
      "image",
      "link",
      "hard_break"
    ],
    "markdown": "![a  \nb](/img.png)\n",
    "html": "<p><img src=\"/img.png\" alt=\"a\nb\" /></p>\n"
  },
  {
    "name": "shortcut reference ignored when references disabled",
    "rules": [
      "link_no_references"
    ],
    "markdown": "[x][ref]\n",
    "html": "<p>[x][ref]</p>\n"
  },
  {
    "name": "collapsed reference uses link label",
    "rules": [
      "link"
    ],
    "markdown": "[x][]\n\n[x]: /url \"title\"\n",
    "html": "<p><a href=\"/url\" title=\"title\">x</a></p>\n"
  },
  {
    "name": "undefined full reference stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x][missing]\n",
    "html": "<p>[x][missing]</p>\n"
  },
  {
    "name": "unclosed full reference opener stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x][\n",
    "html": "<p>[x][</p>\n"
  },
  {
    "name": "invalid full reference label stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x][bad\\q]\n",
    "html": "<p>[x][bad\\q]</p>\n"
  },
  {
    "name": "image alt flattens nested inline children",
    "rules": [
      "image",
      "link",
      "emphasis"
    ],
    "markdown": "![*a* ![b](/b)](/img)\n",
    "html": "<p><img src=\"/img\" alt=\"a b\" /></p>\n"
  },
  {
    "name": "empty inline math stays text",
    "rules": [
      "inline_math"
    ],
    "markdown": "$ $\n",
    "html": "<p>$ $</p>\n"
  },
  {
    "name": "empty strikethrough stays text",
    "rules": [
      "strikethrough"
    ],
    "markdown": "~~~~\n",
    "html": "<p>~~~~</p>\n"
  },
  {
    "name": "strikethrough skips escaped closer",
    "rules": [
      "strikethrough"
    ],
    "markdown": "~~a\\~~b~~\n",
    "html": "<p><del>a\\~~b</del></p>\n"
  },
  {
    "name": "link opener without destination stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x]\n",
    "html": "<p>[x]</p>\n"
  },
  {
    "name": "link bad angle destination stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x](<bad\\url>)\n",
    "html": "<p>[x](&lt;bad\\url&gt;)</p>\n"
  },
  {
    "name": "link missing closing paren stays text",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url \"title\"\n",
    "html": "<p>[x](/url &quot;title&quot;</p>\n"
  },
  {
    "name": "link destination allows escaped closing paren",
    "rules": [
      "link"
    ],
    "markdown": "[x](/a\\)b)\n",
    "html": "<p><a href=\"/a)b\">x</a></p>\n"
  },
  {
    "name": "link double quoted title allows escaped quote",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url \"a\\\"b\")\n",
    "html": "<p><a href=\"/url\" title=\"a&quot;b\">x</a></p>\n"
  },
  {
    "name": "link single quoted title",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url 'title')\n",
    "html": "<p><a href=\"/url\" title=\"title\">x</a></p>\n"
  },
  {
    "name": "link paren title",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url (title))\n",
    "html": "<p><a href=\"/url\" title=\"title\">x</a></p>\n"
  },
  {
    "name": "link plain title text is not accepted",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url plain)\n",
    "html": "<p>[x](/url plain)</p>\n"
  },
  {
    "name": "link label ignores brackets inside code span",
    "rules": [
      "link",
      "inline_code"
    ],
    "markdown": "[a `[b]` c](/url)\n",
    "html": "<p><a href=\"/url\">a <code>[b]</code> c</a></p>\n"
  },
  {
    "name": "link label with unclosed code span still balances brackets",
    "rules": [
      "link",
      "inline_code"
    ],
    "markdown": "[a `code [b]](/url)\n",
    "html": "<p><a href=\"/url\">a `code [b]</a></p>\n"
  },
  {
    "name": "link unterminated title is not accepted",
    "rules": [
      "link"
    ],
    "markdown": "[x](/url \"unterminated)\n",
    "html": "<p>[x](/url &quot;unterminated)</p>\n"
  },
  {
    "name": "inline math cannot close across line break",
    "rules": [
      "inline_math"
    ],
    "markdown": "$a\n$\n",
    "html": "<p>$a\n$</p>\n"
  },
  {
    "name": "inline math allows dollar before digit inside span",
    "rules": [
      "inline_math"
    ],
    "markdown": "$a $2 b$\n",
    "html": "<p><span class=\"math math-inline\">a $2 b</span></p>\n"
  },
  {
    "name": "ruby renders base and annotation",
    "rules": [
      "ruby"
    ],
    "markdown": "[漢(kan)]\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby></p>\n"
  },
  {
    "name": "ruby invalid direct link fallback keeps paren",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)](\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby>(</p>\n"
  },
  {
    "name": "ruby followed by plain text stays ruby plus text",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)]x\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby>x</p>\n"
  },
  {
    "name": "ruby unclosed reference opener stays text",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)][\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby>[</p>\n"
  },
  {
    "name": "ruby empty reference label stays text",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)][]\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby>[]</p>\n"
  },
  {
    "name": "ruby missing reference label stays text",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)][missing]\n",
    "html": "<p><ruby>漢<rt>kan</rt></ruby>[missing]</p>\n"
  },
  {
    "name": "ruby direct link wraps ruby node",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)](/ruby \"Ruby\")\n",
    "html": "<p><a href=\"/ruby\" title=\"Ruby\"><ruby>漢<rt>kan</rt></ruby></a></p>\n"
  },
  {
    "name": "ruby reference link wraps ruby node",
    "rules": [
      "ruby",
      "link"
    ],
    "markdown": "[漢(kan)][term]\n\n[term]: /term\n",
    "html": "<p><a href=\"/term\"><ruby>漢<rt>kan</rt></ruby></a></p>\n"
  },
  {
    "name": "extended autolink trims trailing punctuation and paren",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "https://example.com/a).\n",
    "html": "<p><a href=\"https://example.com/a\">https://example.com/a</a>).</p>\n"
  },
  {
    "name": "extended autolink balances trailing paren",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "https://example.com/(a))\n",
    "html": "<p><a href=\"https://example.com/(a)\">https://example.com/(a)</a>)</p>\n"
  },
  {
    "name": "extended autolink trims bare email suffix punctuation",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "x@example.com/?!.,:*~\n",
    "html": "<p><a href=\"mailto:x@example.com\">x@example.com</a>/?!.,:*~</p>\n"
  },
  {
    "name": "mailto autolink rejects trailing hyphen address",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "mailto:x@example.com-\n",
    "html": "<p>mailto:x@example.com-</p>\n"
  },
  {
    "name": "xmpp autolink rejects trailing hyphen address",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "xmpp:x@example.com-\n",
    "html": "<p>xmpp:x@example.com-</p>\n"
  },
  {
    "name": "xmpp autolink rejects non email address",
    "rules": [
      "extended_autolink"
    ],
    "markdown": "xmpp:not-email/path\n",
    "html": "<p>xmpp:not-email/path</p>\n"
  },
  {
    "name": "inline spoiler trims surrounding spaces",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">! hidden !<\n",
    "html": "<p><span class=\"spoiler\">hidden</span></p>\n"
  },
  {
    "name": "inline spoiler empty content stays text",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">!!<\n",
    "html": "<p>&gt;!!&lt;</p>\n"
  },
  {
    "name": "inline spoiler all spaces keeps one inner space",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">!   !<\n",
    "html": "<p><span class=\"spoiler\"> </span></p>\n"
  },
  {
    "name": "inline spoiler can contain escaped closer prefix",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">!!<a!<\n",
    "html": "<p><span class=\"spoiler\">!&lt;a</span></p>\n"
  },
  {
    "name": "inline spoiler allows indented newline before closer",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">!a\n !<\n",
    "html": "<p><span class=\"spoiler\">a</span></p>\n"
  },
  {
    "name": "inline spoiler rejects plain multiline content",
    "rules": [
      "inline_spoiler"
    ],
    "markdown": ">!a\nb!<\n",
    "html": "<p>&gt;!a\nb!&lt;</p>\n"
  },
  {
    "name": "invalid text directive name stays text",
    "rules": [
      "text_directive"
    ],
    "markdown": ":1\n",
    "html": "<p>:1</p>\n"
  },
  {
    "name": "empty footnote label stays paragraph",
    "rules": [
      "footnote"
    ],
    "markdown": "[^]: bad\n",
    "html": "<p>[^]: bad</p>\n"
  },
  {
    "name": "unterminated text directive stays text",
    "rules": [
      "text_directive"
    ],
    "markdown": ":name[unterminated\n",
    "html": "<p>:name[unterminated</p>\n"
  },
  {
    "name": "text directive supports escaped label and attributes",
    "rules": [
      "text_directive"
    ],
    "markdown": ":name[a\\[b]{#id}\n",
    "html": "<p>a\\[b</p>\n"
  },
  {
    "name": "role invalid name stays text",
    "rules": [
      "role"
    ],
    "markdown": "{1}\n",
    "html": "<p>{1}</p>\n"
  },
  {
    "name": "role missing close brace stays text",
    "rules": [
      "role"
    ],
    "markdown": "{bad\n",
    "html": "<p>{bad</p>\n"
  },
  {
    "name": "role with invalid name characters stays text",
    "rules": [
      "role"
    ],
    "markdown": "{bad name}`x`\n",
    "html": "<p>{bad name}`x`</p>\n"
  },
  {
    "name": "role without backtick opener stays text",
    "rules": [
      "role"
    ],
    "markdown": "{role}x\n",
    "html": "<p>{role}x</p>\n"
  },
  {
    "name": "role without closing backtick stays text",
    "rules": [
      "role"
    ],
    "markdown": "{role}`x\n",
    "html": "<p>{role}`x</p>\n"
  },
  {
    "name": "undefined footnote reference stays text",
    "rules": [
      "footnote"
    ],
    "markdown": "[^x]\n",
    "html": "<p>[^x]</p>\n"
  },
  {
    "name": "footnote-like reference definition stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[^x]: /url\n",
    "html": "<p>[^x]: /url</p>\n"
  },
  {
    "name": "reference definition without destination stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[x]:\n\n",
    "html": "<p>[x]:</p>\n"
  },
  {
    "name": "reference definition with unterminated angle destination stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[x]: <unterminated\n",
    "html": "<p>[x]: &lt;unterminated</p>\n"
  },
  {
    "name": "reference definition rejects newline in angle destination",
    "rules": [
      "link"
    ],
    "markdown": "[x]: <line\nbreak>\n",
    "html": "<p>[x]: &lt;line\nbreak&gt;</p>\n"
  },
  {
    "name": "reference definition requires whitespace before title",
    "rules": [
      "link"
    ],
    "markdown": "[x]: <url>title\n",
    "html": "<p>[x]: &lt;url&gt;title</p>\n"
  },
  {
    "name": "reference definition with unterminated title stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[x]: /url \"unterminated\n",
    "html": "<p>[x]: /url &quot;unterminated</p>\n"
  },
  {
    "name": "reference definition with trailing title text stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[x]: /url \"title\" extra\n",
    "html": "<p>[x]: /url &quot;title&quot; extra</p>\n"
  },
  {
    "name": "reference definition accepts next line title",
    "rules": [
      "link"
    ],
    "markdown": "[x]: /url\n\"title\"\n\n[x]\n",
    "html": "<p><a href=\"/url\" title=\"title\">x</a></p>\n"
  },
  {
    "name": "reference definition rejects title split by blank line",
    "rules": [
      "link"
    ],
    "markdown": "[x]: /url \"title\n\ncontinued\"\n\n[x]\n",
    "html": "<p>[x]: /url &quot;title</p>\n<p>continued&quot;</p>\n<p>[x]</p>\n"
  },
  {
    "name": "reference definition accepts multiline title without blank",
    "rules": [
      "link"
    ],
    "markdown": "[x]: /url \"title\ncontinued\"\n\n[x]\n",
    "html": "<p><a href=\"/url\" title=\"title\ncontinued\">x</a></p>\n"
  },
  {
    "name": "multiline footnote-like reference stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[^x\n]: /url\n",
    "html": "<p>[^x\n]: /url</p>\n"
  },
  {
    "name": "multiline reference without destination stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[\nx]: \n",
    "html": "<p>[\nx]:</p>\n"
  },
  {
    "name": "multiline reference with unterminated title stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[\nx]: /url \"unterminated\n",
    "html": "<p>[\nx]: /url &quot;unterminated</p>\n"
  },
  {
    "name": "multiline reference with trailing text stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[\nx]: /url \"title\" extra\n",
    "html": "<p>[\nx]: /url &quot;title&quot; extra</p>\n"
  },
  {
    "name": "unterminated multiline reference label stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[\n\n",
    "html": "<p>[</p>\n"
  },
  {
    "name": "multiline reference definition resolves multiline shortcut",
    "rules": [
      "link"
    ],
    "markdown": "[x\n]: /url \"title\"\n\n[x\n]\n",
    "html": "<p><a href=\"/url\" title=\"title\">x\n</a></p>\n"
  },
  {
    "name": "html inline tag does not interrupt paragraph",
    "rules": [
      "html_block"
    ],
    "markdown": "a\n<x>\n",
    "html": "<p>a\n&lt;x&gt;</p>\n"
  },
  {
    "name": "html comment interrupts paragraph",
    "rules": [
      "html_block"
    ],
    "markdown": "a\n<!-- c -->\n",
    "html": "<p>a</p>\n&lt;!-- c --&gt;\n"
  },
  {
    "name": "shallow block spoiler stops before plain line",
    "rules": [
      "block_spoiler"
    ],
    "max_container_depth": 1,
    "markdown": ">! quote\nplain\n",
    "html": "<div class=\"spoiler\">\n<p>quote</p>\n</div>\n<p>plain</p>\n"
  },
  {
    "name": "definition following term followed by blank stops list",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\nTerm2\n\n: d\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>desc</dd>\n</dl>\n<p>Term2</p>\n<p>: d</p>\n"
  },
  {
    "name": "definition following indented line stops list",
    "rules": [
      "definition_list"
    ],
    "markdown": "Term\n: desc\n\n  indented\n: d\n",
    "html": "<dl>\n<dt>Term</dt>\n<dd>desc</dd>\n</dl>\n<dl>\n<dt>indented</dt>\n<dd>d</dd>\n</dl>\n"
  },
  {
    "name": "leaf directive unterminated attributes stays paragraph",
    "rules": [
      "leaf_directive"
    ],
    "markdown": "::note{bad\n",
    "html": "<p>::note{bad</p>\n"
  },
  {
    "name": "container directive unterminated label stays paragraph",
    "rules": [
      "container_directive"
    ],
    "markdown": ":::note[unterminated\n:::\n",
    "html": "<p>:::note[unterminated\n:::</p>\n"
  },
  {
    "name": "fenced directive reaches eof before options",
    "rules": [
      "fenced_directive"
    ],
    "markdown": "```{note}\n",
    "html": ""
  },
  {
    "name": "text directive with only attributes renders empty",
    "rules": [
      "text_directive"
    ],
    "markdown": ":name{#id}\n",
    "html": "<p></p>\n"
  },
  {
    "name": "text directive unterminated attributes stays text",
    "rules": [
      "text_directive"
    ],
    "markdown": ":name{bad\n",
    "html": "<p>:name{bad</p>\n"
  },
  {
    "name": "footnote definition stops before unindented line",
    "rules": [
      "footnote"
    ],
    "markdown": "[^x]:\nplain\n",
    "html": "<p>plain</p>\n"
  },
  {
    "name": "footnote definition stops at trailing blank",
    "rules": [
      "footnote"
    ],
    "markdown": "[^x]: first\n\n",
    "html": ""
  },
  {
    "name": "footnote definition skips blank lines before continuation",
    "rules": [
      "footnote"
    ],
    "markdown": "[^x]: first\n\n\n  second\n\n[^x]\n",
    "html": "<p><sup><a href=\"#user-content-fn-x\" id=\"user-content-fnref-x\" data-footnote-ref aria-describedby=\"footnote-label\">1</a></sup></p>\n<section data-footnotes class=\"footnotes\">\n<h2 class=\"sr-only\" id=\"footnote-label\">Footnotes</h2>\n<ol>\n<li id=\"user-content-fn-x\">\n<p>first</p>\n<p>second <a href=\"#user-content-fnref-x\" data-footnote-backref class=\"data-footnote-backref\" aria-label=\"Back to content\">&#8617;</a></p>\n</li>\n</ol>\n</section>\n"
  },
  {
    "name": "escaped caret reference label stays paragraph",
    "rules": [
      "link"
    ],
    "markdown": "[\\^x]: /url\n",
    "html": "<p>[\\^x]: /url</p>\n"
  }
]
